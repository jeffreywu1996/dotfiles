# Setup go/hi #!>>HI<<!#
[ -f /etc/bash.bashrc.d/shell_history_forwarder.sh ] && source /etc/bash.bashrc.d/shell_history_forwarder.sh #!>>HI<<!#
[ -f /etc/bash.bashrc.d/analysis_aliases.sh ] && source /etc/bash.bashrc.d/analysis_aliases.sh

alias pbcopy="~/osc52.sh"
[ -f /google/bin/releases/gemini-cli/tools/gemini ] && alias gemini='/google/bin/releases/gemini-cli/tools/gemini'
[ -f /google/bin/releases/jetski-devs/tools/cli ] && alias jetski='/google/bin/releases/jetski-devs/tools/cli'
# Google
[ -f /etc/bash_completion.d/hgd ] && source /etc/bash_completion.d/hgd
[ -f /etc/bash_completion.d/g4d ] && source /etc/bash_completion.d/g4d
