# Integration test: run the installer on a clean Debian box and assert the result.
#
#   docker build -f Dockerfile.test -t dotfiles-test .
#
# A successful build means install.sh ran end-to-end and all assertions passed.
FROM debian:stable-slim

# install.sh uses sudo + curl + git; a clean Debian image has none of these.
RUN apt-get update \
 && apt-get install -y --no-install-recommends sudo curl git ca-certificates locales \
 && rm -rf /var/lib/apt/lists/*

# Run as a non-root user with passwordless sudo — mirrors a real machine.
RUN useradd -m -s /bin/bash tester \
 && echo 'tester ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/tester
USER tester
WORKDIR /home/tester/dotfiles

COPY --chown=tester:tester . .

# Full install, then assert the outcome. Non-interactive so prompts don't hang.
# Skip the Claude Code CLI in CI to avoid depending on an external installer URL;
# nvm + node still install so the coc.nvim requirement is exercised.
RUN INSTALL_CLAUDE_CODE=false ./install.sh
RUN ./test-integration.sh
