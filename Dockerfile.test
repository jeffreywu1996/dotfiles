# Integration test: run the installer on a clean Debian box and assert the result.
#
#   docker build -f Dockerfile.test -t dotfiles-test .
#
# A successful build means ./install.sh ran end-to-end and all assertions passed.
FROM debian:stable-slim

# Prerequisites the install scripts assume are already present (see README):
# sudo/curl/git for the installers, and vim (install-vim.sh runs `vim +PlugInstall`
# but does not install vim itself).
RUN apt-get update \
 && apt-get install -y --no-install-recommends sudo curl git ca-certificates locales vim \
 && rm -rf /var/lib/apt/lists/*

# Run as a non-root user with passwordless sudo — mirrors a real machine.
RUN useradd -m -s /bin/bash tester \
 && echo 'tester ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/tester
USER tester
WORKDIR /home/tester/dotfiles

COPY --chown=tester:tester . .

# Full install (installs node + rg/fd/fzf/tmux, vim plugins, symlinks), then assert.
RUN ./install.sh
RUN ./test-integration.sh
